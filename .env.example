# ──────────────────────────────────────────
# Required
# ──────────────────────────────────────────

# OpenAI API Key (for api executor - lightweight analysis/review/docs)
OPENAI_API_KEY=sk-proj-your-key-here

# ──────────────────────────────────────────
# Optional: LLM Model
# ──────────────────────────────────────────

# Override default model for api executor (default: gpt-4o-mini)
# AUTO_PIPE_MODEL=gpt-4o-mini

# ──────────────────────────────────────────
# Optional: Claude Code CLI (for console executor)
# ──────────────────────────────────────────

# Console executor uses Claude Code CLI (claude --print)
# Install: https://docs.anthropic.com/en/docs/claude-code
# If not installed, auto-fallbacks to API executor (gpt-4o)

# ──────────────────────────────────────────
# Optional: PostgreSQL (State Persistence)
# ──────────────────────────────────────────

# Shares the same PostgreSQL instance as Langfuse (docker-compose.yml)
# If not set, uses in-memory state (lost on restart)
# AUTOPIPE_DATABASE_URL=postgresql://langfuse:langfuse@localhost:5432/autopipe

# ──────────────────────────────────────────
# Optional: Langfuse (Observability)
# ──────────────────────────────────────────

# Self-hosted Langfuse (docker-compose.yml included)
# 1. Run: docker compose up -d
# 2. Open: http://localhost:3000
# 3. Create account -> Settings -> API Keys
# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# LANGFUSE_HOST=http://localhost:3000
